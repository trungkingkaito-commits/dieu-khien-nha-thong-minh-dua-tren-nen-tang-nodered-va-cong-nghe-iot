        "type": "function",
        "z": "466ad92c66da2565",
        "name": "Parse Attribute value",
        "func": "let szMethod = msg.payload.method;\nlet attr_val = msg.payload.params;\nif (szMethod == 'setAttribute'){\n    msg.type = 1;\n    msg.payload = attr_val;\n}\nif (szMethod == 'setState1'){\n    msg.type = 2;\n    msg.state = attr_val;    \n    if (attr_val == true)\n        msg.payload = true;\n    else\n        msg.payload = false;\n}\nreturn msg;",
